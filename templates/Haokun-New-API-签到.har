[
  {
    "comment": "【好坤 API 登录与会话校验】login_mode 填 cookie（默认）时：仅填写 cookie，模板用 GET /api/user/self 校验会话；填 password 时：填写 username、password，cookie 留空，模板用 POST /api/user/login 建立 QD 会话。该站点登录页当前不要求勾选条款。当前模板不支持二次验证；Cookie 请填写浏览器当前完整 Cookie，勿写入模板文件。 密码模式会从登录响应的 Set-Cookie 中提取会话 Cookie，并显式带入后续签到请求。 该站点受保护接口还要求 New-Api-User 请求头；Cookie 模式请填写 user_id（浏览器 localStorage 的 uid），密码模式会从登录响应自动提取。",
    "request": {
      "method": "{{ 'GET' if (login_mode | default('cookie', true)) == 'cookie' else 'POST' }}",
      "url": "https://api.haokun.cc{{ '/api/user/self' if (login_mode | default('cookie', true)) == 'cookie' else '/api/user/login' }}",
      "headers": [
        {
          "name": "Cookie",
          "value": "{{ cookie if (login_mode | default('cookie', true)) == 'cookie' else '' }}"
        },
        {
          "name": "New-Api-User",
          "value": "{{ user_id | default('', true) }}"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125.0.0.0 Safari/537.36"
        },
        {
          "name": "Accept",
          "value": "application/json, text/plain, */*"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Referer",
          "value": "https://api.haokun.cc/profile"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Origin",
          "value": "https://api.haokun.cc"
        }
      ],
      "cookies": [],
      "data": "{\"username\":{{ username | default('', true) | tojson }},\"password\":{{ password | default('', true) | tojson }}}"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "\\\"success\\\"\\s*:\\s*true",
          "from": "content"
        }
      ],
      "failed_asserts": [
        {
          "re": "^(?:401|403|429)$",
          "from": "status"
        },
        {
          "re": "\\\"require_2fa\\\"\\s*:\\s*true|未登录|请先登录",
          "from": "content"
        }
      ],
      "extract_variables": [
        {
          "name": "account_name",
          "re": "\\\"username\\\"\\s*:\\s*\\\"([^\\\"]+)\\\"",
          "from": "content"
        },
        {
          "name": "account_quota",
          "re": "\\\"quota\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "login_session_cookie",
          "re": "^([^;\\r\\n]+)",
          "from": "header-set-cookie"
        },
        {
          "name": "user_id",
          "re": "\\\"id\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        }
      ]
    }
  },
  {
    "comment": "读取今日签到状态；若当天已经签到，后续提交会按幂等成功处理。",
    "request": {
      "method": "GET",
      "url": "https://api.haokun.cc/api/user/checkin",
      "headers": [
        {
          "name": "Cookie",
          "value": "{{ cookie if (login_mode | default('cookie', true)) == 'cookie' else (login_session_cookie | default('', true)) }}"
        },
        {
          "name": "New-Api-User",
          "value": "{{ user_id | default('', true) }}"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125.0.0.0 Safari/537.36"
        },
        {
          "name": "Accept",
          "value": "application/json, text/plain, */*"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Referer",
          "value": "https://api.haokun.cc/profile"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "re": "\\\"success\\\"\\s*:\\s*true",
          "from": "content"
        }
      ],
      "failed_asserts": [
        {
          "re": "^(?:401|403|429)$",
          "from": "status"
        },
        {
          "re": "未登录|请先登录|签到功能未启用",
          "from": "content"
        }
      ],
      "extract_variables": [
        {
          "name": "checked_in_today",
          "re": "\\\"checked_in_today\\\"\\s*:\\s*(true|false)",
          "from": "content"
        },
        {
          "name": "total_checkins",
          "re": "\\\"total_checkins\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "total_quota",
          "re": "\\\"total_quota\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "min_quota",
          "re": "\\\"min_quota\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "max_quota",
          "re": "\\\"max_quota\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        }
      ]
    }
  },
  {
    "comment": "提交站点原生“立即签到”对应的 POST /api/user/checkin 请求；已签到响应按成功处理。",
    "request": {
      "method": "POST",
      "url": "https://api.haokun.cc/api/user/checkin",
      "headers": [
        {
          "name": "Cookie",
          "value": "{{ cookie if (login_mode | default('cookie', true)) == 'cookie' else (login_session_cookie | default('', true)) }}"
        },
        {
          "name": "New-Api-User",
          "value": "{{ user_id | default('', true) }}"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125.0.0.0 Safari/537.36"
        },
        {
          "name": "Accept",
          "value": "application/json, text/plain, */*"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Referer",
          "value": "https://api.haokun.cc/profile"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        },
        {
          "name": "Origin",
          "value": "https://api.haokun.cc"
        }
      ],
      "cookies": [],
      "data": "{}"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "\\\"success\\\"\\s*:\\s*true|今天(?:已经|已)签到|今日已签到|已经签到",
          "from": "content"
        }
      ],
      "failed_asserts": [
        {
          "re": "^(?:401|403|429)$",
          "from": "status"
        },
        {
          "re": "(?s)\\\"success\\\"\\s*:\\s*false(?!.*(?:今天(?:已经|已)签到|今日已签到|已经签到))",
          "from": "content"
        },
        {
          "re": "Turnstile|验证失败|签到功能未启用|未登录|请先登录",
          "from": "content"
        }
      ],
      "extract_variables": [
        {
          "name": "sign_message",
          "re": "\\\"message\\\"\\s*:\\s*\\\"([^\\\"]*)\\\"",
          "from": "content"
        },
        {
          "name": "quota_awarded",
          "re": "\\\"quota_awarded\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "checkin_date",
          "re": "\\\"checkin_date\\\"\\s*:\\s*\\\"([^\\\"]+)\\\"",
          "from": "content"
        }
      ]
    }
  },
  {
    "comment": "签到后复查状态，确保今日状态已更新为已签到。",
    "request": {
      "method": "GET",
      "url": "https://api.haokun.cc/api/user/checkin",
      "headers": [
        {
          "name": "Cookie",
          "value": "{{ cookie if (login_mode | default('cookie', true)) == 'cookie' else (login_session_cookie | default('', true)) }}"
        },
        {
          "name": "New-Api-User",
          "value": "{{ user_id | default('', true) }}"
        },
        {
          "name": "User-Agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/125.0.0.0 Safari/537.36"
        },
        {
          "name": "Accept",
          "value": "application/json, text/plain, */*"
        },
        {
          "name": "Accept-Language",
          "value": "zh-CN,zh;q=0.9,en;q=0.8"
        },
        {
          "name": "Referer",
          "value": "https://api.haokun.cc/profile"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "re": "\\\"success\\\"\\s*:\\s*true",
          "from": "content"
        },
        {
          "re": "\\\"checked_in_today\\\"\\s*:\\s*true",
          "from": "content"
        }
      ],
      "failed_asserts": [
        {
          "re": "^(?:401|403|429)$",
          "from": "status"
        },
        {
          "re": "未登录|请先登录|签到功能未启用",
          "from": "content"
        }
      ],
      "extract_variables": [
        {
          "name": "final_checked_in_today",
          "re": "\\\"checked_in_today\\\"\\s*:\\s*(true|false)",
          "from": "content"
        },
        {
          "name": "final_total_checkins",
          "re": "\\\"total_checkins\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        },
        {
          "name": "final_total_quota",
          "re": "\\\"total_quota\\\"\\s*:\\s*(\\d+)",
          "from": "content"
        }
      ]
    }
  },
  {
    "comment": "生成 QD 推送日志；不输出密码、Cookie 或会话令牌。",
    "request": {
      "method": "POST",
      "url": "api://util/unicode",
      "headers": [],
      "cookies": [],
      "data": "content=好坤 API签到结果：{{sign_message | default('已完成或今日已签到', true)}}，账号：{{account_name | default('已登录用户', true)}}，本次奖励：{{quota_awarded | default('未返回', true)}}，累计签到：{{final_total_checkins | default(total_checkins, true)}} 天，累计额度：{{final_total_quota | default(total_quota, true)}}"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        },
        {
          "re": "\\\"状态\\\"\\s*:\\s*\\\"200\\\"",
          "from": "content"
        }
      ],
      "failed_asserts": [],
      "extract_variables": [
        {
          "name": "__log__",
          "re": "\\\"转换后\\\"\\s*:\\s*\\\"(.*)\\\"",
          "from": "content"
        }
      ]
    }
  }
]
