[
    {
        "comment": "【使用说明】需要使用 ymting/qd:20260716.2 或 latest 镜像。cookie 填当前完整 Cookie；sign_mode 填 random 随机、填 fixed 固定5积分、留空默认 fixed；browser_fingerprint 和 browser_user_agent 留空默认 chrome + auto。变量名必须保持英文，不要改成中文说明。403 时按 Response Diagnostic 更新 Cookie 或排查指纹。",
        "request": {
            "method": "GET",
            "url": "https://www.nodeseek.com/api/account/credit/page-1",
            "headers": [
                {
                    "name": "X-QD-Impersonate",
                    "value": "{{browser_fingerprint | default('chrome', true)}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                },
                {
                    "name": "User-Agent",
                    "value": "{{browser_user_agent | default('auto', true)}}"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9,en;q=0.8"
                },
                {
                    "name": "Referer",
                    "value": "https://www.nodeseek.com/board"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "^200$",
                    "from": "status"
                },
                {
                    "re": "\"success\"\\s*:\\s*true",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "^(?:401|403|429)$",
                    "from": "status"
                },
                {
                    "re": "Just a moment|cf-chl|Cloudflare|请先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "balance_before",
                    "re": "\"data\"\\s*:\\s*\\[\\s*\\[\\s*-?\\d+\\s*,\\s*(\\d+)",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "执行签到：任务变量 sign_mode 填 random 启用随机积分；填 fixed 固定获得5积分；留空默认 fixed。不要填写 true 或 false。",
        "request": {
            "method": "POST",
            "url": "https://www.nodeseek.com/api/attendance?random={{ 'true' if (sign_mode | default('fixed', true) | lower | trim) == 'random' else 'false' }}",
            "headers": [
                {
                    "name": "X-QD-Impersonate",
                    "value": "{{browser_fingerprint | default('chrome', true)}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                },
                {
                    "name": "User-Agent",
                    "value": "{{browser_user_agent | default('auto', true)}}"
                },
                {
                    "name": "Accept",
                    "value": "*/*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9,en;q=0.8"
                },
                {
                    "name": "Content-Type",
                    "value": "application/json"
                },
                {
                    "name": "Origin",
                    "value": "https://www.nodeseek.com"
                },
                {
                    "name": "Referer",
                    "value": "https://www.nodeseek.com/board"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "^(?:200|500)$",
                    "from": "status"
                },
                {
                    "re": "\"success\"\\s*:\\s*true|今天已完成签到",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "^(?:401|403|429)$",
                    "from": "status"
                },
                {
                    "re": "Just a moment|cf-chl|Cloudflare|Cookie.*(?:失效|过期)|请先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "sign_message",
                    "re": "\"message\"\\s*:\\s*\"([^\"]+)\"",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "查询签到后的积分流水",
        "request": {
            "method": "GET",
            "url": "https://www.nodeseek.com/api/account/credit/page-1",
            "headers": [
                {
                    "name": "X-QD-Impersonate",
                    "value": "{{browser_fingerprint | default('chrome', true)}}"
                },
                {
                    "name": "Cookie",
                    "value": "{{cookie}}"
                },
                {
                    "name": "User-Agent",
                    "value": "{{browser_user_agent | default('auto', true)}}"
                },
                {
                    "name": "Accept",
                    "value": "application/json, text/plain, */*"
                },
                {
                    "name": "Accept-Language",
                    "value": "zh-CN,zh;q=0.9,en;q=0.8"
                },
                {
                    "name": "Referer",
                    "value": "https://www.nodeseek.com/board"
                }
            ],
            "cookies": []
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "^200$",
                    "from": "status"
                },
                {
                    "re": "\"success\"\\s*:\\s*true",
                    "from": "content"
                }
            ],
            "failed_asserts": [
                {
                    "re": "^(?:401|403|429)$",
                    "from": "status"
                },
                {
                    "re": "Just a moment|cf-chl|Cloudflare|请先登录",
                    "from": "content"
                }
            ],
            "extract_variables": [
                {
                    "name": "current_balance",
                    "re": "\"data\"\\s*:\\s*\\[\\s*\\[\\s*-?\\d+\\s*,\\s*(\\d+)",
                    "from": "content"
                },
                {
                    "name": "sign_reward",
                    "re": "\\[\\s*(\\d+)\\s*,\\s*\\d+\\s*,\\s*\"签到收益\\d+个鸡腿\"",
                    "from": "content"
                },
                {
                    "name": "sign_time",
                    "re": "\\[\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\"签到收益\\d+个鸡腿\"\\s*,\\s*\"([^\"]+)\"",
                    "from": "content"
                }
            ]
        }
    },
    {
        "comment": "生成签到日志",
        "request": {
            "method": "POST",
            "url": "api://util/unicode",
            "headers": [],
            "cookies": [],
            "data": "content=签到模式：{{ '随机积分' if (sign_mode | default('fixed', true) | lower | trim) == 'random' else '固定5积分' }}，签到结果：{{sign_message}}，最近签到奖励：{{sign_reward}}，当前余额：{{current_balance}}，签到时间：{{sign_time}}"
        },
        "rule": {
            "success_asserts": [
                {
                    "re": "^200$",
                    "from": "status"
                },
                {
                    "re": "\"状态\"\\s*:\\s*\"200\"",
                    "from": "content"
                }
            ],
            "failed_asserts": [],
            "extract_variables": [
                {
                    "name": "__log__",
                    "re": "\"转换后\"\\s*:\\s*\"(.*)\"",
                    "from": "content"
                }
            ]
        }
    }
]
